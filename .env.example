# Jason-MCP configuration — copy this file to ".env" and fill in your values.
# (.env is gitignored; never commit your real token.)

# Your YouTrack workspace URL (no trailing slash).
YOUTRACK_URL=https://rango.youtrack.cloud

# Your personal YouTrack API token.
# Get one: YouTrack -> your avatar -> Profile -> Account Security -> New token...
#   give it a name and the "YouTrack" scope, then copy the perm:... value.
YOUTRACK_API_TOKEN=perm:xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Default agile board used when a tool/skill doesn't name one.
YOUTRACK_DEFAULT_BOARD=Rango Dev

# --- optional ---
# YOUTRACK_VERIFY_SSL=true
# TRANSPORT=stdio
